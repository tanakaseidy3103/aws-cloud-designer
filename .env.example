# =========================================================================
# AWS S3 Cloud Integration Credentials
# Copy this file to '.env.local' and populate it with your AWS configurations.
# Keep '.env.local' out of git history (already included in .gitignore).
# =========================================================================

# AWS IAM credentials for S3 operations
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# Target S3 deployment details
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
